# ─────────────────────────────────────────────────────────────────────────────
# RecapAI — environment template. Copy to `.env` and fill in as needed.
#
#   cp .env.example .env
#
# The app runs with ZERO keys in mock mode (LLM_PROVIDER=mock), which returns a
# canned, fabricated result so the demo flow works end-to-end with no network.
# Set LLM_PROVIDER=openai and provide an OpenAI key for real output.
# ─────────────────────────────────────────────────────────────────────────────

# Backend ---------------------------------------------------------------------

# LLM provider: mock | auto | openai
#   mock   → deterministic fabricated output, no key, no network (default for demos)
#   auto   → use OpenAI if its key is set, else fall back to mock
#   openai → require OpenAI (Whisper transcription + GPT-4o summarization)
LLM_PROVIDER=mock

# Only needed when LLM_PROVIDER is auto/openai.
OPENAI_API_KEY=

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recapai
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100
CORS_ORIGINS=http://localhost:5173

# Frontend --------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api
